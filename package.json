{
  "name": "guides",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "22.22.3",
    "npm": "10.9.8"
  },
  "packageManager": "npm@10.9.8",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "test": "vitest run",
    "test:locales": "vitest run src/i18n/locale-keys-check.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix": "npm run format && npm run lint:fix",
    "check": "npm run lint && npm run format:check && npm run test:locales && npm test",
    "ready": "npm run fix && npm run check",
    "deps": "node scripts/check-dependencies.mjs",
    "deps:upgrade": "npm-check-updates -u && npm install"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-toggle-group": "1.1.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "i18next": "25.10.10",
    "lucide-react": "0.544.0",
    "next-themes": "0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "15.7.4",
    "react-router-dom": "7.15.1",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "npm-check-updates": "22.2.0",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.59.4",
    "vite": "7.3.3",
    "vitest": "3.2.4"
  }
}
